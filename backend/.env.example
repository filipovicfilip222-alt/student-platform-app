# ══════════════════════════════════════════════════════════════════════════════
# Studentska Platforma — Backend Environment Variables
# Kopiraj ovaj fajl u .env i popuni vrednosti pre pokretanja.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://studentska:studentska_pass@postgres:5432/studentska_platforma
POSTGRES_USER=studentska
POSTGRES_PASSWORD=studentska_pass
POSTGRES_DB=studentska_platforma

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_pass@redis:6379/0
REDIS_PASSWORD=redis_pass

# ── JWT / Security ─────────────────────────────────────────────────────────────
# Generiši sa: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MinIO / File Storage ───────────────────────────────────────────────────────
# MINIO_ENDPOINT — internal (Docker DNS) host used by backend for S3 ops.
# MINIO_PUBLIC_ENDPOINT — host that ends up in presigned URLs; must be
# reachable from the browser / external curl.
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET_APPOINTMENTS=appointment-files
MINIO_BUCKET_AVATARS=professor-avatars
MINIO_BUCKET_IMPORTS=bulk-imports
MINIO_BUCKET_DOCUMENTS=document-requests
MINIO_SECURE=false

# ── SMTP / Email ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@fon.bg.ac.rs
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@fon.bg.ac.rs
EMAILS_FROM_NAME=StudentPlus

# ── Google Programmable Search Engine ─────────────────────────────────────────
GOOGLE_PSE_API_KEY=
GOOGLE_PSE_CX=

# ── Email Domain Whitelist ─────────────────────────────────────────────────────
ALLOWED_STUDENT_DOMAINS=student.fon.bg.ac.rs,student.etf.bg.ac.rs
ALLOWED_STAFF_DOMAINS=fon.bg.ac.rs,etf.bg.ac.rs

# ── CORS / Frontend ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_pass@redis:6379/2

# ── Web Push / VAPID (KORAK 1 Prompta 2 / PRD §5.3) ───────────────────────────
# Generiši par sa: docker compose run --rm backend python scripts/generate_vapid_keys.py
# Public key se servira frontend-u kroz GET /api/v1/notifications/vapid-public-key.
# Private key NIKAD ne napušta server — koristi ga pywebpush za potpis JWT-a.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@studentska-platforma.local
