# ══════════════════════════════════════════════════════════════════════════════
# Studentska Platforma — Frontend Environment Variables (Next.js)
# Kopiraj ovaj fajl u .env.local i popuni vrednosti pre pokretanja.
# NEXT_PUBLIC_* varijable su dostupne u browseru — ne stavljaj tajne vrednosti!
# ══════════════════════════════════════════════════════════════════════════════

# ── API ────────────────────────────────────────────────────────────────────────
# URL backend API-ja (dostupan u browseru)
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# ── WebSocket ──────────────────────────────────────────────────────────────────
# WebSocket URL za chat i notifikacije
NEXT_PUBLIC_WS_URL=ws://localhost

# ── Aplikacija ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Konsultacije FON & ETF

# ── MinIO / File Storage ───────────────────────────────────────────────────────
# Javni URL za MinIO (za prikaz avatara i fajlova)
NEXT_PUBLIC_MINIO_PUBLIC_URL=http://localhost:9000

# ── Okruženje ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=development
